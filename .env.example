# GroundDesing Pro — Variables de entorno
# Copiar a .env y ajustar valores

# Base de datos
DB_PASSWORD=gdpdev
DATABASE_URL=postgres://gdp:gdpdev@localhost:5432/grounddesing

# API
PORT=3001
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
WEB_URL=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email (SMTP) — dejar vacío para modo dev (log-only, sin envío real)
# Proveedores recomendados: Resend, SendGrid, Mailgun, Gmail SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=GroundDesing Pro <noreply@grounddesing.pro>

# Stripe billing — dejar vacío para modo demo (sin pagos reales)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_PROFESSIONAL=
